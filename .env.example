# AdForge Environment Variables

# Google API Key for Gemini Models (Vision & Text Copywriting) and Cloud TTS (Speech Synthesis)
# Generate one at: https://aistudio.google.com/
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: Stock Video sourcing API Keys
# Sign up at https://www.pexels.com/api/ to download portrait clips automatically
PEXELS_API_KEY=YOUR_PEXELS_API_KEY_HERE
# Sign up at https://pixabay.com/api/docs/ for an alternative source
PIXABAY_API_KEY=YOUR_PIXABAY_API_KEY_HERE
